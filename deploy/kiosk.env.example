# Copy to /etc/kiosk.env on the TV host (chmod 600, owned by root).
# Then: systemctl daemon-reload && systemctl enable --now kiosk

# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
KIOSK_SECRET_KEY=replace-me-with-32-random-bytes

# REQUIRED when deploying. Forces create_app() to reject a missing SECRET_KEY.
FLASK_ENV=production

# Optional — override DB backup retention (default 30 days).
# KIOSK_BACKUP_RETENTION_DAYS=30
